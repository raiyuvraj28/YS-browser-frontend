{
  "name": "ys-browser-frontend-only",
  "version": "1.0.0",
  "description": "Futuristic desktop browser built with React, Tailwind v4 and Electron using LocalStorage",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev:frontend": "vite",
    "dev:electron": "electron electron/main.js",
    "dev": "concurrently -k -n \"vite,electron\" -c \"cyan,yellow\" \"npm run dev:frontend\" \"npm run dev:electron\"",
    "build": "npm install && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@google/generative-ai": "^0.1.1",
    "lucide-react": "^0.378.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0-alpha.12",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^30.0.1",
    "tailwindcss": "^4.0.0-alpha.12",
    "vite": "^5.2.11"
  }
}
